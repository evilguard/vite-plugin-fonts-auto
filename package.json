    "woff2",
    "preload",
    "tailwind"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KozlovDS/vite-plugin-fonts-auto.git"
  },
  "bugs": {
    "url": "https://github.com/KozlovDS/vite-plugin-fonts-auto/issues"
  },
  "homepage": "https://github.com/KozlovDS/vite-plugin-fonts-auto#readme",
  "license": "MIT",
  "author": "kozlovv.ds <kozlovv.ds@ya.ru>",
  "type": "module",
  "main": "index.js",
  "sideEffects": false,

  "dependencies": {
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.0",
    "opentype.js": "^1.3.4",
    "cheerio": "^1.1.2"
  },
  "devDependencies": {
